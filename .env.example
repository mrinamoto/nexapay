# NexaPay educational demo configuration
# Copy this file to .env for your own notes if needed.
# This static HTML/CSS/JS version does not load .env automatically.
# For the beginner static setup, paste the same public values into:
# js/config/supabase.js

# Safe to expose in frontend code only when it is the public anon key.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Optional deployment notes. These are examples, not required by the app.
NEXAPAY_SITE_URL=http://127.0.0.1:5173
NEXAPAY_RESET_REDIRECT_URL=http://127.0.0.1:5173/reset-password.html
NEXAPAY_PRODUCTION_SITE_URL=https://YOUR-USERNAME.github.io/nexapay/
NEXAPAY_PRODUCTION_RESET_REDIRECT_URL=https://YOUR-USERNAME.github.io/nexapay/reset-password.html
NEXAPAY_PRODUCTION_LOGIN_URL=https://YOUR-USERNAME.github.io/nexapay/login.html

# Never put these in frontend code or commit them to GitHub:
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=
# REAL_BANK_API_KEY=
# REAL_PAYMENT_GATEWAY_SECRET=
